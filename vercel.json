{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/**/*.php",
      "use": "vercel-php"
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/get-presigned-url",
      "dest": "backend/index.js"
    },
    {
      "src": "/api/(.*).php",
      "dest": "backend/api/$1.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "backend/index.js"
    }
  ]
}
