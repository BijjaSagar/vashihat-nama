{
    "version": 2,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ],
    "builds": [
        {
            "src": "api/**/*.php",
            "use": "vercel-php"
        }
    ],
    "crons": [
        {
            "path": "/api/admin/trigger_heartbeat_check",
            "schedule": "0 0 * * *"
        }
    ]
}